<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          android:versionCode="1"
          android:versionName="1.0"
          package="com.finder.app"
          android:installLocation="auto">

	<uses-sdk android:minSdkVersion="21" android:targetSdkVersion="30" />

	<application
        android:label="Finder"
        android:theme="@style/MainTheme"
        android:allowBackup="true">

		<!-- Main activity -->
		<activity android:name=".MainActivity" />

		<!-- Background location foreground service -->
		<service
            android:name=".Services.BackgroundLocationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

		<!--
            Layer 4: Watchdog periodic job.
            android:permission is REQUIRED — JobScheduler will refuse to bind without it.
        -->
		<service
            android:name=".Services.WatchdogJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:enabled="true"
            android:exported="true" />

		<!--
            Layer 3: Receives the AlarmManager broadcast from OnTaskRemoved.
            android:exported="false" — only our own app sends this intent.
        -->
		<receiver
            android:name=".Receivers.RestartReceiver"
            android:enabled="true"
            android:exported="false" />

		<!--
            Layer 5: Restarts the service after phone reboot.
        -->
		<receiver
            android:name=".Receivers.BootReceiver"
            android:enabled="true"
            android:exported="true">
			<intent-filter>
				<action android:name="android.intent.action.BOOT_COMPLETED" />
			</intent-filter>
		</receiver>

	</application>

	<!-- Network -->
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

	<!-- Location -->
	<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
	<uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
	<uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

	<!-- Foreground service -->
	<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
	<uses-permission android:name="android.permission.INSTANT_APP_FOREGROUND_SERVICE" />

	<!-- Wake lock -->
	<uses-permission android:name="android.permission.WAKE_LOCK" />

	<!-- Boot completed — required for BootReceiver AND JobScheduler SetPersisted(true) -->
	<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

	<!-- Biometric -->
	<uses-permission android:name="android.permission.USE_FINGERPRINT" />
	<uses-permission android:name="android.permission.USE_BIOMETRIC" />

</manifest>