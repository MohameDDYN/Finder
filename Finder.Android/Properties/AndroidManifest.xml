<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          android:versionCode="1"
          android:versionName="1.0"
          package="com.finder.app"
          android:installLocation="auto">

	<uses-sdk android:minSdkVersion="21" android:targetSdkVersion="33" />

	<application
        android:label="Finder"
        android:theme="@style/MainTheme"
        android:allowBackup="true">

		<!-- Main activity -->
		<activity android:name=".MainActivity" />

		<!-- Background location foreground service -->
		<service
            android:name=".Services.BackgroundLocationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

		<!--
            Layer 4: Watchdog periodic job.
            android:permission is REQUIRED — JobScheduler will refuse to bind without it.
        -->
		<service
            android:name=".Services.WatchdogJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:enabled="true"
            android:exported="true" />

		<!--
            Layer 3: AlarmManager broadcast from OnTaskRemoved.
            Fires 3 seconds after the user swipes the app from Recent Tasks.
            android:exported="false" — only our own app sends this intent.
        -->
		<receiver
            android:name=".Receivers.RestartReceiver"
            android:enabled="true"
            android:exported="false" />

		<!--
            Layer 5: Restarts the service after device reboot.
        -->
		<receiver
            android:name=".Receivers.BootReceiver"
            android:enabled="true"
            android:exported="true">
			<intent-filter>
				<action android:name="android.intent.action.BOOT_COMPLETED" />
			</intent-filter>
		</receiver>

		<!--
            Layer 6: Restarts the service after a self-update (APK replacement).

            Android sends MY_PACKAGE_REPLACED only to the package being replaced,
            so no other app can spoof this intent.

            Why exported="true":
              The broadcast is sent by the Android package manager (a system process),
              not by our own app. exported="true" is required for system-sent broadcasts
              to be delivered reliably across all API levels (21–33).

            No extra permission needed — MY_PACKAGE_REPLACED is a protected broadcast
            that only the system can send.
        -->
		<receiver
            android:name=".Receivers.PackageReplacedReceiver"
            android:enabled="true"
            android:exported="true">
			<intent-filter>
				<action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
			</intent-filter>
		</receiver>

		<!--
            FileProvider — required for APK installation on API 24+.

            Without this, FileProvider.GetUriForFile() throws:
              "No FileProvider matches the given authority"

            Rules:
              • android:authorities MUST match FILE_PROVIDER_AUTHORITY
                in ApkInstaller.cs → "com.finder.app.fileprovider"
              • android:exported="false" — never expose this to other apps
              • android:grantUriPermissions="true" — allows the system
                installer to temporarily read the APK content:// URI
              • @xml/file_paths references Resources/xml/file_paths.xml
        -->
		<provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.finder.app.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
			<meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
		</provider>

	</application>

	<!-- ── Network ─────────────────────────────────────────────────────────── -->
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

	<!-- ── Location ────────────────────────────────────────────────────────── -->
	<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
	<uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
	<uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

	<!-- ── Foreground service ──────────────────────────────────────────────── -->
	<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
	<uses-permission android:name="android.permission.INSTANT_APP_FOREGROUND_SERVICE" />

	<!-- ── Wake lock ───────────────────────────────────────────────────────── -->
	<uses-permission android:name="android.permission.WAKE_LOCK" />

	<!-- ── Boot completed ─────────────────────────────────────────────────── -->
	<!-- Required for BootReceiver AND JobScheduler SetPersisted(true) -->
	<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

	<!-- ── Biometric ───────────────────────────────────────────────────────── -->
	<uses-permission android:name="android.permission.USE_FINGERPRINT" />
	<uses-permission android:name="android.permission.USE_BIOMETRIC" />

	<!-- ── APK Installation ────────────────────────────────────────────────── -->
	<!--
        REQUEST_INSTALL_PACKAGES:
          Required on API 26+ (Android 8.0+) to allow installing APKs.
          This is a normal (install-time) permission — no runtime dialog.
          The user still needs to enable "Install unknown apps" for Finder
          in Settings, which Android prompts automatically if not set.
    -->
	<uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

	<!--
        WRITE_EXTERNAL_STORAGE:
          Required ONLY on API 21-28 (Android 5.0-9.0) to write the APK
          to the downloads folder. On API 29+ the app uses its own private
          external directory (GetExternalFilesDir) which requires no permission.
          android:maxSdkVersion="28" ensures this is not requested on newer devices.
    -->
	<uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

</manifest>