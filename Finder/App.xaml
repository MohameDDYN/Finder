<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Finder.Converters"
             x:Class="Finder.App">
    <Application.Resources>
        <ResourceDictionary>

            <local:InverseBoolConverter x:Key="InverseBoolConverter" />
            <!-- ===== Color Palette ===== -->
            <Color x:Key="PrimaryColor">#1565C0</Color>
            <Color x:Key="PrimaryLightColor">#1E88E5</Color>
            <Color x:Key="PrimaryDarkColor">#0D47A1</Color>
            <Color x:Key="AccentColor">#43A047</Color>
            <Color x:Key="AccentLightColor">#66BB6A</Color>
            <Color x:Key="DangerColor">#E53935</Color>
            <Color x:Key="DangerLightColor">#EF5350</Color>
            <Color x:Key="WarningColor">#FB8C00</Color>
            <Color x:Key="BackgroundColor">#F0F4F8</Color>
            <Color x:Key="CardColor">#FFFFFF</Color>
            <Color x:Key="TextPrimaryColor">#1A237E</Color>
            <Color x:Key="TextSecondaryColor">#546E7A</Color>
            <Color x:Key="TextLightColor">#90A4AE</Color>
            <Color x:Key="DividerColor">#E0E0E0</Color>
            <Color x:Key="DotInactiveColor">#CFD8DC</Color>
            <Color x:Key="DotActiveColor">#43A047</Color>

            <!-- ===== Global Button Styles ===== -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="HeightRequest" Value="52" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,4" />
            </Style>

            <Style x:Key="SuccessButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentColor}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="HeightRequest" Value="52" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,4" />
            </Style>

            <Style x:Key="DangerButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource DangerColor}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="HeightRequest" Value="52" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,4" />
            </Style>

            <Style x:Key="NumpadButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
                <Setter Property="CornerRadius" Value="40" />
                <Setter Property="WidthRequest" Value="72" />
                <Setter Property="HeightRequest" Value="72" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="8" />
            </Style>

            <Style x:Key="CardFrameStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,6" />
            </Style>

            <Style x:Key="SectionLabelStyle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextSecondaryColor}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,12,0,4" />
            </Style>

            <Style x:Key="EntryStyle" TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextLightColor}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="BackgroundColor" Value="Transparent" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>