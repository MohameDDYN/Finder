<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Finder.Views.MainPage"
             Title="Finder"
             BackgroundColor="{StaticResource BackgroundColor}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="⚙" Clicked="OnSettingsToolbarClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <StackLayout Padding="16,12" Spacing="0">

            <!-- ── Status Card ────────────────────────────────────────── -->
            <Frame Style="{StaticResource CardFrameStyle}" Margin="0,0,0,12">
                <StackLayout Spacing="6" HorizontalOptions="Center">

                    <Label Text="📍" FontSize="36" HorizontalOptions="Center" />

                    <Label Text="{Binding StatusText}"
                           TextColor="{Binding StatusColor}"
                           FontSize="15"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding LastUpdateText}"
                           TextColor="{StaticResource TextLightColor}"
                           FontSize="12"
                           HorizontalOptions="Center" />
                </StackLayout>
            </Frame>

            <!-- ══════════════════════════════════════════════════════════
                 ── Update Progress Card ─────────────────────────────────
                 Visible ONLY when a /update command is being processed.
                 Hidden at all other times (IsVisible bound to IsUpdating).
                 ══════════════════════════════════════════════════════════ -->
            <Frame Style="{StaticResource CardFrameStyle}"
                   Margin="0,0,0,12"
                   IsVisible="{Binding IsUpdating}"
                   BackgroundColor="#E3F2FD">

                <StackLayout Spacing="10">

                    <!-- Card header row: icon + title + animated spinner -->
                    <StackLayout Orientation="Horizontal" Spacing="10">

                        <Label Text="⬇️"
                               FontSize="22"
                               VerticalOptions="Center" />

                        <Label Text="APP UPDATE"
                               Style="{StaticResource SectionLabelStyle}"
                               TextColor="{StaticResource PrimaryDarkColor}"
                               VerticalOptions="Center"
                               HorizontalOptions="FillAndExpand" />

                        <!-- Spinner visible while downloading (progress < 100) -->
                        <ActivityIndicator
                            IsRunning="{Binding IsDownloading}"
                            IsVisible="{Binding IsDownloading}"
                            Color="{StaticResource PrimaryColor}"
                            WidthRequest="24"
                            HeightRequest="24"
                            VerticalOptions="Center" />
                    </StackLayout>

                    <!-- Status text: "Downloading… 45%" / "Installing…" / etc. -->
                    <Label Text="{Binding UpdateStatusText}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimaryColor}"
                           HorizontalOptions="Center" />

                    <!-- Progress bar — fills left to right as download advances -->
                    <ProgressBar
                        Progress="{Binding UpdateProgressFraction}"
                        ProgressColor="{StaticResource PrimaryColor}"
                        BackgroundColor="{StaticResource DividerColor}"
                        HeightRequest="8" />

                    <!-- Percentage label row -->
                    <StackLayout Orientation="Horizontal">

                        <Label Text="0%"
                               FontSize="11"
                               TextColor="{StaticResource TextLightColor}"
                               HorizontalOptions="StartAndExpand" />

                        <!-- Centre percentage changes as download progresses -->
                        <Label Text="{Binding UpdateProgressPercent,
                                       StringFormat='{0}%'}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}"
                               HorizontalOptions="Center" />

                        <Label Text="100%"
                               FontSize="11"
                               TextColor="{StaticResource TextLightColor}"
                               HorizontalOptions="EndAndExpand" />
                    </StackLayout>

                    <!-- Sub-status line: size downloaded / speed / stage -->
                    <Label Text="{Binding UpdateSubStatusText}"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondaryColor}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                </StackLayout>
            </Frame>

            <!-- ── Tracking Controls Card ─────────────────────────────── -->
            <Frame Style="{StaticResource CardFrameStyle}" Margin="0,0,0,12">
                <StackLayout Spacing="6">

                    <Label Text="TRACKING CONTROLS"
                           Style="{StaticResource SectionLabelStyle}"
                           Margin="0,0,0,6" />

                    <Button x:Name="btnStart"
                            Text="▶  Start Tracking"
                            Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding StartServiceCommand}" />

                    <Button x:Name="btnStop"
                            Text="■  Stop Tracking"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding StopServiceCommand}" />

                    <Button Text="↻  Refresh Status"
                            Style="{StaticResource PrimaryButtonStyle}"
                            BackgroundColor="{StaticResource PrimaryLightColor}"
                            Command="{Binding RefreshStatusCommand}" />

                </StackLayout>
            </Frame>

            <!-- ── Actions Card ───────────────────────────────────────── -->
            <Frame Style="{StaticResource CardFrameStyle}" Margin="0,0,0,12">
                <StackLayout Spacing="6">

                    <Label Text="ACTIONS"
                           Style="{StaticResource SectionLabelStyle}"
                           Margin="0,0,0,6" />

                    <Button Text="📤  Share Current Location"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ShareLocationCommand}" />

                    <Button Text="📅  Location History"
                            Style="{StaticResource PrimaryButtonStyle}"
                            BackgroundColor="{StaticResource TextSecondaryColor}"
                            Command="{Binding ViewHistoryCommand}" />

                </StackLayout>
            </Frame>

            <!-- ── Activity indicator (general busy state) ───────────── -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryColor}"
                               Margin="0,8" />

            <!-- ── Footer ─────────────────────────────────────────────── -->
            <Label Text="Finder tracks your location and sends&#10;updates to your Telegram bot."
                   TextColor="{StaticResource TextLightColor}"
                   FontSize="12"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,16,0,8" />

        </StackLayout>
    </ScrollView>
</ContentPage>